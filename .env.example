# Dhara AI — Global Environment Template
# Copy this to .env and fill in your secrets.

# ── LLM API Keys ───────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-pro-preview
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── External Service Keys ──────────────────────────
SERP_API_KEY=your_serp_api_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Core Infrastructure (Local Defaults) ──────────
# These match the docker-compose defaults
DATABASE_URL=postgresql+asyncpg://redevelopment:redevelopment@localhost:5435/orchestrator_db
REDIS_URL=redis://localhost:6379
SECRET_KEY=generate_a_long_random_secret_key_here

# ── Microservice Routing (Local) ──────────────────
# The system will auto-switch to internal Docker names if it detects a container environment.
SITE_ANALYSIS_URL=http://localhost:8001
HEIGHT_URL=http://localhost:8002
PREMIUM_URL=http://localhost:8003
REPORT_URL=http://localhost:8004
PR_CARD_URL=http://localhost:8005
RAG_URL=http://localhost:8006
MCGM_PROPERTY_URL=http://localhost:8007
DP_REPORT_URL=http://localhost:8008

# ── App Settings ───────────────────────────────────
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Storage & Notifications ───────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@dharaai.com
SMTP_FROM_NAME=Dhara AI

# ── Vector DB (Milvus) ────────────────────────────
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=documents

#──────────Razor Pay─────────────────────────────
RAZORPAY_KEY_ID=rzp_test_
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_custom_webhook_secret