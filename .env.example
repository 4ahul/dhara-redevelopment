# =========================================
# DHARA AI — Environment Variables
# Copy this to .env and fill in your values
# =========================================

# ── LLM Configuration ────────────────────
# Set ONE of these (priority: Gemini → Anthropic → Ollama → OpenAI-compatible):

# Option 1: Google Gemini (default)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Option 2: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Option 3: Ollama (Local)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:latest

# Option 4: OpenAI-compatible (vLLM, LM Studio)
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_API_KEY=your-key
# OPENAI_MODEL=llama-3.1-8b-instruct

# ── LLM Vision OCR (PR Card Extraction) ─
# Used by pr_card_scraper for OCR. Set at least one:
GEMINI_API_KEY_OCR=your-gemini-key-for-ocr
# OPENAI_API_KEY_OCR=your-openai-key-for-ocr

# ── Google Maps ──────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-key

# ── SerpApi (Fallback Geocoding) ────────
SERP_API_KEY=your-serpapi-key

# ── App Secret (change in production!) ───
SECRET_KEY=change-me-in-production-use-a-real-secret

# ── Clerk Authentication ─────────────────
CLERK_SECRET_KEY=sk_test_your_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_JWT_KEY=your_jwt_key_from_clerk_dashboard
CLERK_JWT_ISSUER=clerk.accounts.dev

# ── PostgreSQL ───────────────────────────
DATABASE_URL=postgresql+asyncpg://redevelopment:redevelopment@postgres:5432/redevelopment

# ── Redis (Session Cache) ────────────────
REDIS_URL=redis://redis:6379

# ── Cloudinary (File Storage) ────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── SMTP (Email) ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@dharaai.com
SMTP_FROM_NAME=Dhara AI

# ── CORS Origins ─────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Report Output ────────────────────────
REPORT_OUTPUT_DIR=/tmp/reports

# ── HuggingFace (RAG Embeddings) ────────
HF_TOKEN=your-huggingface-token

# ── OAuth (Social Login) ────────────────
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# ── Service URLs (Docker Compose) ────────
SITE_ANALYSIS_URL=http://site_analysis:8001
HEIGHT_URL=http://height_service:8002
PREMIUM_URL=http://premium_checker:8004
REPORT_URL=http://report_generator:8005
PR_CARD_URL=http://pr_card_scraper:8006
RAG_URL=http://rag_service:8007
MCGM_PROPERTY_URL=http://mcgm_property_lookup:8008
DP_REPORT_URL=http://dp_report_service:8009
