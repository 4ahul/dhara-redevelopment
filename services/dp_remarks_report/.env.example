DPRMARKS_PASSWORD=

# Payment automation
SKIP_PAYMENT=false
BUSINESS_UPI_VPA=rahulsagar280103@okaxis
PAYMENT_TIMEOUT_SECONDS=300
PAYMENT_QUEUE_WAIT_SECONDS=600

# Redis (for payment queue lock)
