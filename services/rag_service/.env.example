# Backend Configuration
SECRET_KEY=your-super-secret-key-change-in-production
SESSION_SECRET=your-session-secret-key

# Server
PORT=8000
HOST=0.0.0.0
DEBUG=True
FRONTEND_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/dhara

# Milvus Vector Database
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TOKEN=

# Zilliz Cloud (for export script)
ZILLIZ_CLUSTER=
ZILLIZ_TOKEN=

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_HOST=http://localhost:11434
MODEL=qwen2.5:3b
EMBEDDING_MODEL=text-embedding-3-small

# OpenAI API Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Web Search (Serper API)
SERPER_API_KEY=
ENABLE_WEB_SEARCH=true
ENABLE_DDG=true

# Reranker (multilingual cross-encoder)
ENABLE_RERANKER=false

# Google Maps Configuration
GOOGLE_MAPS_API_KEY=

# Vertex AI Search Configuration
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
VERTEX_DATA_STORE_ID=
VERTEX_ORG_ID=
ENABLE_VERTEX_SEARCH=true

# LangSmith Observability (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=dhara-rag
LANGSMITH_TRACING=true

# SMTP Email Configuration (for email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-email@gmail.com
FROM_NAME=Dhara RAG

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret