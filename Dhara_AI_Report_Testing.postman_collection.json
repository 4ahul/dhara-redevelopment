{
	"info": {
		"_postman_id": "dhara-ai-report-testing",
		"name": "Dhara AI — Report Generator Testing",
		"description": "End-to-end testing for the report generation pipeline.\n\n**Setup:**\nToken is permanent (never expires) — no setup needed.\nChange `society_id` variable if testing with a different society.\n\n**Flow:**\n- Use \"1. Orchestrator\" folder for full E2E (agent calls all microservices)\n- Use \"2. Report Generator Direct\" folder to test templates directly (no agent)\n- Use \"3. Individual Microservices\" to test each service standalone",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "orchestrator_url",
			"value": "http://localhost:8000"
		},
		{
			"key": "report_url",
			"value": "http://localhost:8005"
		},
