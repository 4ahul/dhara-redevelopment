			"key": "token",
			"value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJjMzQzNjJjOC0wNzU3LTQ3MDktODMwOC0zNTVjNzk0NTU2MzkiLCJlbWFpbCI6ImFkbWluQGRoYXJhYWkuY29tIiwicm9sZSI6IkFETUlOIiwibmFtZSI6IkRoYXJhIEFJIFRlc3QgQWRtaW4iLCJpYXQiOjE3NzYyNzQ2MDUsImlzcyI6ImRoYXJhLWFpIn0.hS2Ll-eSk0mzuoE3yOFRJ80ddoh7AH_BvCVYKqYzn04"
		},
		{
			"key": "society_id",
			"value": "cf9dcb2e-f499-4548-9e73-179df7ea090a"
		},
		{
			"key": "report_id",
			"value": ""
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "0. Health Checks",
			"item": [
				{
					"name": "Orchestrator Health",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"url": "{{orchestrator_url}}/health"
					}
				},
				{
					"name": "Report Generator Health",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"url": "{{report_url}}/health"
					}
				}
			]
		},
		{
			"name": "1. Orchestrator — Full E2E",
			"description": "Full pipeline: Society → Agent → All Microservices → Report.\nTakes ~2 minutes. Poll the GET endpoint until status=completed.",
			"item": [
				{
					"name": "1a. Trigger Feasibility Report",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.id) {",
									"    pm.collectionVariables.set('report_id', json.id);",
									"    console.log('Report ID saved: ' + json.id);",
									"}",
									"pm.test('Status is 201', function() {",
									"    pm.response.to.have.status(201);",
									"});",
									"pm.test('Status is pending', function() {",
									"    pm.expect(json.status).to.eql('pending');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"url": "{{orchestrator_url}}/api/feasibility-reports",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"society_id\": \"{{society_id}}\",\n    \"title\": \"Postman E2E Test\"\n}"
						}
					}
				},
				{
					"name": "1b. Poll Report Status",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"console.log('Status: ' + json.status);",
									"",
									"if (json.status === 'processing' || json.status === 'pending') {",
									"    console.log('Still processing... run again in 10s');",
									"}",
									"",
									"if (json.status === 'completed') {",
									"    console.log('DONE!');",
									"    var od = json.output_data || {};",
									"    console.log('Reports: ' + (od.reports_count || 0));",
									"    console.log('Tool calls: ' + (od.tool_calls || 0));",
									"    if (od.all_reports) {",
									"        od.all_reports.forEach(function(r) {",
									"            console.log('  → ' + r.scheme + ' (' + r.redevelopment_type + '): ' + r.path);",
									"        });",
									"    }",
									"    if (od.tool_log) {",
									"        od.tool_log.forEach(function(t) {",
									"            var err = t.result.error ? ' ERROR: ' + t.result.error : '';",
									"            console.log('  [' + t.tool + ']' + err);",
									"        });",
									"    }",
									"}",
									"",
									"pm.test('Status is not failed', function() {",
									"    pm.expect(json.status).to.not.eql('failed');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"url": "{{orchestrator_url}}/api/feasibility-reports/{{report_id}}"
					}
				},
				{
					"name": "1c. List All Reports",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{orchestrator_url}}/api/feasibility-reports?page=1&page_size=10",
							"host": ["{{orchestrator_url}}"],
							"path": ["api", "feasibility-reports"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "page_size", "value": "10" }
							]
						}
					}
				}
			]
		},
		{
			"name": "2. Report Generator — Direct",
			"description": "Call report generator directly (no agent, no auth).\nInstant response — returns .xlsx file.",
